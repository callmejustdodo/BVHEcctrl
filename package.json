{
  "name": "bvhecctrl",
  "version": "0.0.18",
  "author": "Erdong Chen",
  "license": "MIT",
  "description": "A simple bvh character controller for R3F",
  "keywords": [
    "react",
    "three",
    "threejs",
    "react-three-fiber",
    "control",
    "character-control"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/pmndrs/BVHEcctrl.git"
  },
  "files": [
    "dist/*"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "sideEffects": false,
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "three-mesh-bvh": "^0.9.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@react-three/drei": "^10.0.5",
    "@react-three/fiber": "^9.1.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "leva": "^0.10.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.8.2",
    "vite": "^6.2.4"
  },
  "peerDependencies": {
    "@react-three/drei": ">=9.0",
    "@react-three/fiber": ">=8.0",
    "react": ">=19.1.0",
    "react-dom": ">=19.1.0",
    "three": ">=0.177.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc",
    "preview": "vite preview"
  }
